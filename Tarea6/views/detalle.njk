{% extends "base.njk" %}

{% block title %}{{ producto.título }} - Tienda Prado{% endblock %}

{% block content %}
    
    <div class="text-center my-5">
        <h2 class="display-6" style="color: #4a5c6a; font-family: 'Times New Roman', serif; font-size: 1.5rem; letter-spacing: 1px;">IMPRESIONES</h2>
    </div>

    <div class="row mb-5 align-items-start">
        
        <div class="col-md-6 mb-4 mb-md-0">
            <div class="bg-light d-flex justify-content-center align-items-center p-5" style="min-height: 500px; background-color: #f7f7f7 !important;">
                <img src="/public/imagenes/{{ producto.imagen }}" class="img-fluid shadow-sm" alt="{{ producto.título }}" style="max-height: 450px; object-fit: contain;">
            </div>
        </div>

        <div class="col-md-6 ps-md-5 pt-md-3">
            
            <h1 class="mb-4" style="font-family: 'Georgia', 'Times New Roman', Times, serif; font-size: 2.2rem; font-weight: 400; line-height: 1.2; color: #2c2c2c;">
                {{ producto.título }}
            </h1>

            <div class="mb-4" style="font-family: 'Georgia', 'Times New Roman', Times, serif; font-size: 1.05rem; font-weight: 400; line-height: 1.7; color: #444444;">
                {{ producto.descripción | safe }}
            </div>

            <div class="mb-5">
                <span style="font-family: 'Georgia', 'Times New Roman', Times, serif; font-size: 1.25rem; font-weight: 400; color: #2c2c2c;">
                    {{ producto.precio }} €
                </span>
            </div>

            <form action="/al-carrito/{{ producto.id }}" method="POST">
            <div class="d-flex align-items-center gap-3">
                
                <input type="number" class="form-control text-center" value="1" min="1" name="cantidad" aria-label="Cantidad" style="width: 65px; height: 45px; border-radius: 0; border: 1px solid #ddd; color: #555;">

                <button class="btn text-white px-4" type="submit" style="background-color: #767676; border-radius: 0; height: 45px; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 0.75rem; font-weight: 500; letter-spacing: 1.5px;">
                    AÑADIR A LA CESTA
                </button>

                <div class="ms-auto d-flex gap-4 text-muted">
                    <a href="#" class="text-muted text-decoration-none">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                        </svg>
                    </a>
                    <a href="#" class="text-muted text-decoration-none">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                            <circle cx="18" cy="5" r="3"></circle>
                            <circle cx="6" cy="12" r="3"></circle>
                            <circle cx="18" cy="19" r="3"></circle>
                            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
                            <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
                        </svg>
                    </a>
                </div>
            </div>
            </form>

        </div>
    </div>

{% endblock %}
