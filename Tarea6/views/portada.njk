{% extends "base.njk" %}

{% block title %}Impresiones - Tienda Prado{% endblock %}

{% block content %}

    <div class="text-center my-5">
        <h1 class="display-6" style="color: #4a5c6a; font-family: 'Times New Roman', serif;">IMPRESIONES</h1>
    </div>

    {% if busqueda %}
        <div class="alert alert-secondary text-center mb-4" role="alert">
            Se han encontrado <strong>{{ cards | length }}</strong> resultados para: "<em>{{ busqueda }}</em>"
        </div>
    {% endif %}

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-5">
        {% for card in cards %}
            <div class="col">
                <a href="/producto/{{ card.id }}" class="text-decoration-none text-dark">
                    <div class="card h-100 border-0 text-center">
                        <div class="bg-light p-4 mb-3 d-flex align-items-center justify-content-center" style="aspect-ratio: 1 / 1;">
                            <img src="/public/imagenes/{{ card.imagen }}" class="img-fluid shadow-sm" alt="{{ card.título }}" style="max-height: 100%; object-fit: contain;">
                        </div>
                        <div class="card-body p-0">
                            <h5 class="card-title fs-6 mb-2" style="font-weight: normal;">{{ card.título }}</h5>
                            <p class="card-text text-muted">{{ card.precio }} €</p>
                        </div>
                    </div>
                </a>
            </div>
        {% else %}
            <div class="col-12 text-center text-muted">
                <p>No hay productos disponibles en este momento.</p>
            </div>
        {% endfor %}
    </div>

{% endblock %}
