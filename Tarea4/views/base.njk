<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Tienda Prado{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <style>
        body {
            font-family: "Times New Roman", Times, serif;
            color: #333;
        }
        .navbar-brand {
            font-family: 'Georgia', 'Times New Roman', Times, serif;
            font-size: 1.8rem;
            font-weight: 700;
            letter-spacing: 4px;
            color: #2c2c2c;
        }
        .nav-link {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            font-size: 0.7rem;
            font-weight: 400;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: #767676;
        }
        .nav-link.active {
            font-weight: 600;
            color: #2c2c2c;
        }
    </style>
</head>
<body>

    <header class="border-bottom pb-2 mb-4">
        <div class="container pt-3">
            <nav class="navbar navbar-expand-lg navbar-light bg-white">
                <div class="container-fluid px-0">
                    <a class="navbar-brand" href="/">TIENDA PRADO</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarContent">
                        <div class="d-flex align-items-center ms-auto">
                        <form class="d-flex" action="/buscar" method="GET">
                            <div class="input-group">
                                <input class="form-control rounded-pill px-3" type="search" name="busqueda" placeholder="Buscar..." value="{{ busqueda }}">
                                <button class="btn btn-outline-secondary rounded-pill ms-2" type="submit">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                                    </svg>
                                </button>
                            </div>
                        </form>
                        <a href="#" class="d-flex align-items-center ms-3 text-decoration-none" style="color: #767676;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                <rect x="4" y="7" width="16" height="15" rx="1" ry="1"></rect>
                                <path d="M16 7V5a4 4 0 0 0-8 0v2"></path>
                            </svg>
                        </a>
                        </div>
                    </div>
                </div>
            </nav>
            <ul class="nav justify-content-center mt-3">
                <li class="nav-item"><a class="nav-link text-muted" href="#">Libros</a></li>
                <li class="nav-item"><a class="nav-link text-muted" href="#">Exposiciones</a></li>
                <li class="nav-item"><a class="nav-link text-muted" href="#">Colaboraciones</a></li>
                <li class="nav-item"><a class="nav-link active" href="/">Impresiones</a></li>
                <li class="nav-item"><a class="nav-link text-muted" href="#">Hogar</a></li>
            </ul>
        </div>
    </header>

    <main class="container mb-5">
        {% block content %}{% endblock %}
    </main>

    <footer class="bg-light text-center text-muted py-4 mt-auto border-top">
        <div class="container">
            <p class="mb-0">&copy; 2026 Tienda Prado. Todos los derechos reservados.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
</body>
</html>
